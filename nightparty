
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>今夏辣一波綠島・偏鄉小學堂</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=ZCOOL+KuaiLe&family=Klee+One:wght@400;600&family=Fredoka:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root{
    --cream:#FFF6E5;
    --cream-deep:#FFEBC7;
    --board:#1F3D2E;
    --board-light:#2C5240;
    --chalk:#FDFDF6;
    --sun:#FF8A3D;
    --mango:#FFC93D;
    --sky:#4FB4E8;
    --ocean:#1D6FA5;
    --forest:#4CAF6D;
    --coral:#FF6F91;
    --berry:#E85D75;
    --grape:#9B7EDE;
    --teal:#26A69A;
    --ink:#4A3728;
    --wood:#B98554;
    --wood-dark:#8A5F38;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{height:100%;}
  body{
    font-family:'Noto Sans TC', sans-serif;
    background:var(--cream);
    color:var(--ink);
    overflow:hidden;
    -webkit-font-smoothing:antialiased;
  }
  .display{font-family:'ZCOOL KuaiLe', 'Noto Sans TC', sans-serif;}
  .chalkfont{font-family:'Klee One', 'Noto Sans TC', sans-serif;}
  .accent{font-family:'Fredoka', sans-serif;}

  #app{position:relative; width:100vw; height:100vh; overflow:hidden;}
  .screen{
    position:absolute; inset:0;
    display:none;
    align-items:center; justify-content:center;
    flex-direction:column;
    padding:24px;
  }
  .screen.active{display:flex;}

  button{ font-family:inherit; cursor:pointer; border:none; background:none; }
  button:focus-visible, .opt:focus-visible, .card:focus-visible { outline:3px solid var(--mango); outline-offset:3px; }

  /* ---------- HOME ---------- */
  #screen-home{
    background:
      radial-gradient(circle at 88% 10%, #FFE7A8 0%, transparent 40%),
      linear-gradient(var(--cream), var(--cream-deep));
  }
  .sun{
    position:absolute; top:6%; right:8%;
    width:120px; height:120px; border-radius:50%;
    background:radial-gradient(circle at 35% 35%, #FFE29A, var(--mango) 70%);
    box-shadow:0 0 0 14px rgba(255,201,61,0.18), 0 0 0 28px rgba(255,201,61,0.10);
    animation:spin 18s linear infinite;
  }
  @keyframes spin{ to{ transform:rotate(360deg);} }
  .waves{ position:absolute; left:0; right:0; bottom:0; width:100%; line-height:0; }
  .waves svg{ width:100%; height:auto; display:block; }
  .cloud{ position:absolute; opacity:0.85; animation:float 14s ease-in-out infinite; }
  @keyframes float{ 0%,100%{ transform:translateY(0);} 50%{ transform:translateY(-14px);} }

  .home-card{
    position:relative; z-index:2;
    background:var(--chalk);
    border-radius:32px;
    padding:56px 64px;
    text-align:center;
    box-shadow:0 20px 0 rgba(74,55,40,0.08), 0 24px 50px rgba(74,55,40,0.15);
    border:4px dashed var(--sun);
    max-width:720px;
  }
  .eyebrow-badge{
    display:inline-block; background:var(--coral); color:white;
    padding:6px 22px; border-radius:999px; font-size:15px; font-weight:700;
    letter-spacing:2px; margin-bottom:18px; transform:rotate(-3deg);
    box-shadow:0 4px 0 rgba(0,0,0,0.12);
  }
  .home-title{ font-size:52px; color:var(--ocean); line-height:1.3; }
  .home-title span{ color:var(--sun); }
  .home-sub{ margin-top:10px; font-size:20px; color:var(--ink); opacity:0.75; }
  .btn-start{
    margin-top:36px; background:var(--sun); color:white; font-size:22px; font-weight:700;
    padding:18px 48px; border-radius:999px; box-shadow:0 6px 0 #C9611C;
    transition:transform .15s;
    animation:pulse 2.2s ease-in-out infinite;
  }
  .btn-start:active{ transform:translateY(6px); box-shadow:0 0 0 #C9611C; }
  @keyframes pulse{ 0%,100%{ transform:scale(1);} 50%{ transform:scale(1.045);} }

  /* ---------- MENU ---------- */
  #screen-menu{ background:var(--cream); }
  .menu-header{ text-align:center; margin-bottom:28px; }
  .menu-header h2{ font-size:34px; color:var(--ocean); }
  .menu-header p{ opacity:0.7; margin-top:4px; }
  .grid{
    display:grid; grid-template-columns:repeat(4, minmax(150px,1fr));
    gap:22px; max-width:1000px; width:100%;
  }
  .card{
    position:relative;
    background:var(--chalk);
    border-radius:20px;
    padding:26px 14px 20px;
    text-align:center;
    box-shadow:0 8px 0 rgba(74,55,40,0.10), 0 10px 22px rgba(74,55,40,0.10);
    border-left:10px solid var(--c);
    transition:transform .18s, box-shadow .18s;
  }
  .card:hover{ transform:translateY(-6px) rotate(-1deg); box-shadow:0 12px 0 rgba(74,55,40,0.10), 0 18px 30px rgba(74,55,40,0.14); }
  .card .ic{ font-size:44px; display:block; margin-bottom:10px; }
  .card .nm{ font-size:20px; font-weight:700; color:var(--ink); }
  .card .ct{ margin-top:6px; font-size:13px; color:white; background:var(--c); display:inline-block; padding:3px 12px; border-radius:999px; }

  /* ---------- INTRO ---------- */
  .intro-screen{
    background:linear-gradient(160deg, var(--c), var(--cd));
    color:white; text-align:center;
  }
  .intro-badge{
    width:170px; height:170px; border-radius:50%; background:white;
    display:flex; align-items:center; justify-content:center;
    font-size:80px; margin:0 auto 26px; box-shadow:0 14px 0 rgba(0,0,0,0.12);
    animation:bounce 1.8s ease-in-out infinite;
  }
  @keyframes bounce{ 0%,100%{ transform:translateY(0);} 50%{ transform:translateY(-16px);} }
  .intro-name{ font-size:56px; }
  .intro-line{ font-size:22px; margin-top:14px; opacity:0.95; }
  .btn-go{
    margin-top:34px; background:white; padding:16px 44px; border-radius:999px;
    font-size:20px; font-weight:700; box-shadow:0 6px 0 rgba(0,0,0,0.18);
  }
  .btn-go:active{ transform:translateY(6px); box-shadow:none; }

  /* ---------- QUESTION (Blackboard) ---------- */
  #screen-question{
    background:
      radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.05), transparent 60%),
      var(--board);
  }
  .board-frame{
    width:min(920px, 92vw);
    background:var(--board-light);
    border-radius:18px;
    border:14px solid var(--wood);
    box-shadow:0 20px 0 var(--wood-dark), 0 24px 50px rgba(0,0,0,0.35);
    padding:38px 44px 30px;
    position:relative;
  }
  .board-top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:22px; flex-wrap:wrap; gap:10px;}
  .subj-pill{
    display:flex; align-items:center; gap:8px;
    background:var(--c); color:white; padding:7px 18px; border-radius:999px;
    font-weight:700; font-size:15px;
  }
  .progress-dots{ display:flex; gap:7px; align-items:center; }
  .dot{ width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.25); }
  .dot.done{ background:var(--mango); }
  .dot.now{ background:white; transform:scale(1.3); }
  .progress-text{ color:rgba(255,255,255,0.6); font-size:13px; margin-left:8px; }
  .sample-tag{ font-size:11px; background:rgba(255,255,255,0.15); color:white; padding:2px 10px; border-radius:999px; margin-left:8px; }

  .q-text{
    color:var(--chalk); font-size:30px; line-height:1.6; text-align:center;
    padding:10px 6px 26px; min-height:90px;
  }
  .q-image{
    display:block; max-width:100%; max-height:220px; margin:0 auto 18px;
    background:var(--chalk); border-radius:12px; padding:14px 18px;
    box-shadow:0 4px 0 rgba(0,0,0,0.25);
  }
  .options{ display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:8px; }
  .opt{
    position:relative;
    border:2.5px dashed rgba(255,255,255,0.5);
    color:var(--chalk); border-radius:14px; padding:16px 18px; font-size:19px; text-align:left;
    background:rgba(255,255,255,0.03);
    display:flex; gap:10px; align-items:center;
    transition:opacity .3s;
  }
  .opt .lbl{ font-family:'Fredoka'; font-weight:700; color:var(--mango); }
  .opt.correct{ border-style:solid; border-color:var(--mango); background:rgba(255,201,61,0.12); }
  .opt.correct::after{ content:'✔'; position:absolute; right:14px; color:var(--mango); font-size:20px; }
  .opt.faded{ opacity:0.35; }

  .answer-box{
    display:none; text-align:center; margin-top:6px; padding:18px 20px;
    border-top:2px dashed rgba(255,255,255,0.3);
  }
  .answer-box.show{ display:block; animation:pop .4s ease; }
  @keyframes pop{ from{ transform:scale(0.85); opacity:0;} to{ transform:scale(1); opacity:1;} }
  .answer-label{ color:var(--mango); font-size:14px; letter-spacing:3px; font-weight:700; }
  .answer-text{ color:white; font-size:26px; margin-top:8px; }

  .board-actions{ display:flex; justify-content:center; margin-top:22px; }
  .btn-reveal{
    background:var(--mango); color:var(--ink); font-weight:700; font-size:19px;
    padding:14px 42px; border-radius:999px; box-shadow:0 5px 0 #C99B1A;
  }
  .btn-reveal:active{ transform:translateY(5px); box-shadow:none; }

  .nav-row{
    width:min(920px, 92vw); display:flex; justify-content:space-between; align-items:center;
    margin-top:20px;
  }
  .nav-btn{ color:var(--chalk); opacity:0.8; font-size:15px; padding:8px 16px; }
  .nav-btn:hover{ opacity:1; }
  .nav-btn:disabled{ opacity:0.25; cursor:default; }
  .nav-mid{ display:flex; gap:10px; }

  /* ---------- SUBJECT COMPLETE ---------- */
  .complete-screen{ background:linear-gradient(160deg, var(--c), var(--cd)); color:white; text-align:center; }
  .complete-emoji{ font-size:90px; animation:bounce 1.6s ease-in-out infinite; }
  .complete-title{ font-size:44px; margin-top:10px; }
  .complete-actions{ display:flex; gap:16px; margin-top:30px; }
  .btn-secondary{ background:rgba(255,255,255,0.2); color:white; padding:14px 32px; border-radius:999px; font-weight:700; font-size:17px; border:2px solid rgba(255,255,255,0.5); }
  .btn-primary2{ background:white; color:var(--ink); padding:14px 32px; border-radius:999px; font-weight:700; font-size:17px; }

  .home-back{ position:fixed; top:18px; left:18px; z-index:50; }
  .home-back button{ background:rgba(74,55,40,0.08); color:var(--ink); padding:9px 18px; border-radius:999px; font-size:14px; font-weight:600; }
  #screen-question .home-back button, .intro-screen .home-back button, .complete-screen .home-back button{ background:rgba(255,255,255,0.18); color:white; }

  .kbd-hint{ position:fixed; bottom:14px; right:18px; font-size:12px; color:var(--ink); opacity:0.4; z-index:50; }
  #screen-question .kbd-hint, .intro-screen .kbd-hint, .complete-screen .kbd-hint{ color:white; opacity:0.5; }

  @media (max-width:720px){
    .grid{ grid-template-columns:repeat(2, 1fr); }
    .home-title{ font-size:34px; }
    .options{ grid-template-columns:1fr; }
    .board-frame{ padding:26px 20px 22px; }
    .q-text{ font-size:22px; }
  }
</style>
</head>
<body>
<div id="app">

  <!-- HOME -->
  <div class="screen active" id="screen-home">
    <div class="cloud" style="top:14%; left:8%; font-size:46px;">☁️</div>
    <div class="cloud" style="top:22%; left:20%; font-size:30px; animation-delay:2s;">☁️</div>
    <div class="sun"></div>
    <div class="home-card">
      <div class="eyebrow-badge">2026 夏日限定</div>
      <div class="home-title display">🏝️ 今夏辣一波綠島<br><span>偏鄉小學堂</span></div>
      <div class="home-sub">晚會問答大挑戰・叮咚～上課囉！</div>
      <button class="btn-start display" onclick="goTo('menu')">🔔 開始上課</button>
    </div>
    <div class="waves">
      <svg viewBox="0 0 1440 150" preserveAspectRatio="none"><path fill="#4FB4E8" fill-opacity="0.55" d="M0,80 C240,140 480,20 720,60 C960,100 1200,40 1440,80 L1440,150 L0,150 Z"></path><path fill="#1D6FA5" fill-opacity="0.6" d="M0,110 C260,60 500,140 740,100 C980,60 1200,120 1440,90 L1440,150 L0,150 Z"></path></svg>
    </div>
  </div>

  <!-- SUBJECT MENU -->
  <div class="screen" id="screen-menu">
    <div class="home-back"><button onclick="goTo('home')">← 封面</button></div>
    <div class="menu-header">
      <h2 class="display">📚 選擇今天的課程</h2>
      <p>點一堂課，開始今天的偏鄉小學堂吧！</p>
    </div>
    <div class="grid" id="subject-grid"></div>
  </div>

  <!-- SUBJECT INTRO -->
  <div class="screen intro-screen" id="screen-intro">
    <div class="home-back"><button onclick="goTo('menu')">← 課表</button></div>
    <div class="intro-badge" id="intro-icon">📖</div>
    <div class="intro-name display" id="intro-name">國語課</div>
    <div class="intro-line" id="intro-line">起立～立正～敬禮～上課囉！</div>
    <button class="btn-go display" onclick="startQuestions()">開始答題 →</button>
  </div>

  <!-- QUESTION -->
  <div class="screen" id="screen-question">
    <div class="home-back"><button onclick="goTo('menu')">← 課表</button></div>
    <div class="board-frame">
      <div class="board-top">
        <div class="subj-pill" id="q-subj-pill"><span id="q-subj-icon">📖</span><span id="q-subj-name">國語</span></div>
        <div class="progress-dots" id="progress-dots"></div>
      </div>
      <img class="q-image" id="q-image" style="display:none;" alt="題目圖片">
      <div class="q-text chalkfont" id="q-text">題目內容</div>
      <div class="options" id="q-options"></div>
      <div class="answer-box" id="answer-box">
        <div class="answer-label">解　答</div>
        <div class="answer-text chalkfont" id="answer-text"></div>
      </div>
      <div class="board-actions">
        <button class="btn-reveal display" id="btn-reveal" onclick="revealAnswer()">✏️ 公佈解答</button>
      </div>
    </div>
    <div class="nav-row">
      <button class="nav-btn" id="btn-prev" onclick="prevQuestion()">◀ 上一題</button>
      <div class="nav-mid"><span class="progress-text" id="q-counter">第 1 / 2 題</span></div>
      <button class="nav-btn" id="btn-next" onclick="nextQuestion()">下一題 ▶</button>
    </div>
    <div class="kbd-hint">空白鍵：公佈解答 ／ ← → 切換題目</div>
  </div>

  <!-- SUBJECT COMPLETE -->
  <div class="screen complete-screen" id="screen-complete">
    <div class="complete-emoji">🎉</div>
    <div class="complete-title display" id="complete-title">國語課上完囉！</div>
    <div class="intro-line">同學們表現得太棒了，掌聲鼓勵鼓勵！</div>
    <div class="complete-actions">
      <button class="btn-secondary display" onclick="goTo('menu')">回課表</button>
      <button class="btn-primary2 display" id="btn-next-subject" onclick="nextSubject()">下一堂課 →</button>
    </div>
  </div>

</div>

<script>
/* ============================================================
   📌 題目資料區：之後把正式題目貼給我，我會直接更新這個陣列。
   每一科 subjects[i].questions 可以放任意題數。
   題型 type: "choice"（選擇題，需要 options + answerIndex）
            "text"  （簡答題，只需要 answer 文字）
   目前每一科先放 2 題「範例題」示意呈現方式，方便你確認風格。
   ============================================================ */
const subjects = [
  { id:'chinese', name:'國語', icon:'📖', color:'#FF6F91', colorDark:'#D94570', line:'起立～立正～敬禮～準備考國語囉！',
    questions:[
      { type:'text', q:'「我達達的馬蹄是美麗的錯誤」是現代詩作《錯誤》，而誰是作者呢？', answer:'鄭愁予' },
      { type:'text', q:'著名〈木蘭詩〉：東市買「什麼」、西市買「什麼」、南市買「什麼」、北市買「什麼」？（市場與物品需全對）', answer:'東市買「駿馬」、西市買「鞍韉」、南市買「轡頭」、北市買「長鞭」' },
      { type:'text', q:'生僻字：玉字部的「玊」讀音為何？', answer:'ㄙㄨˋ' },
      { type:'text', q:'生僻字：「奀」讀音為何？', answer:'ㄇㄤˊ' }
    ]
  },
  { id:'math', name:'數學', icon:'🔢', color:'#4FB4E8', colorDark:'#2E86C1', line:'數字寶寶們，準備好了嗎？開始上課！',
    questions:[
      { type:'text', image:'data:image/png;base64,', q:'如圖所示，請問三角形、圓形、正方形分別代表什麼數字？', answer:'三角形 ＝ 3，圓形 ＝ 8，正方形 ＝ 9' }
    ]
  },
  { id:'science', name:'自然', icon:'🌿', color:'#4CAF6D', colorDark:'#2E7D4F', line:'大自然的奧秘，讓我們一起探索！',
    questions:[
      { type:'text', q:'請舉出一種血液是藍色的生物。', answer:'鱟、章魚、烏賊（答對一種即可）' },
      { type:'text', q:'一般正常的成年人有多少顆牙齒？', answer:'32 顆' }
    ]
  },
  { id:'social', name:'社會', icon:'🌍', color:'#FF8A3D', colorDark:'#C9611C', line:'認識我們生活的這片土地！',
    questions:[
      { type:'text', q:'我們都知道世界第一高峰是珠穆朗瑪峰（海拔 8,848 公尺），那第二高峰呢？', answer:'喬戈里峰（又稱 K2 峰），海拔 8,611 公尺' },
      { type:'text', q:'世界最大的湖泊、也是最大的鹹水湖是？', answer:'裏海（位於歐洲與亞洲交界處，中亞西部）' }
    ]
  },
  { id:'health', name:'健康', icon:'❤️‍🩹', color:'#E85D75', colorDark:'#B93E56', line:'健康寶寶時間，一起來認識身體！',
    questions:[
      { type:'text', q:'在愛滋病議題中常聽到「U=U」，請問這邊的 U 代表什麼？', answer:'愛滋病毒量測不到＝傳不出去' },
      { type:'text', q:'2025 年造成台灣國人死亡人數最多的癌症是什麼？', answer:'肺癌' },
      { type:'text', q:'台灣同婚合法化是在民國幾年？', answer:'民國 108 年' },
      { type:'text', q:'人有 23 對、共 46 條染色體，而唐氏症是哪一對染色體多了一條呢？', answer:'第 21 對' }
    ]
  },
  { id:'life', name:'綜合', icon:'🧩', color:'#9B7EDE', colorDark:'#6F4FB0', line:'綜合活動課，動手動腦最好玩！',
    questions:[
      { type:'text', q:'請問水果之王是誰？', answer:'榴槤' },
      { type:'text', q:'請問水果之后是誰？', answer:'山竹' },
      { type:'text', image:'data:image/jpeg;base64,', q:'請說出圖片中物品的正式名稱？', answer:'牛粒' },
      { type:'text', image:'data:image/jpeg;base64,', q:'請說出圖片中物品的正式名稱？', answer:'邦提圈' },
      { type:'text', image:'data:image/jpeg;base64,', q:'請說出圖片中物品的正式名稱？', answer:'魔帶' }
    ]
  },
  { id:'art', name:'美術', icon:'🎨', color:'#FFC93D', colorDark:'#C99B1A', line:'拿起畫筆，畫出綠島的美！',
    questions:[
      { type:'text', q:'【待補充・範例題】把藍色和黃色混在一起會變成什麼顏色？', answer:'（範例答案）綠色' }
    ]
  },
  { id:'pe', name:'體育', icon:'⚽', color:'#26A69A', colorDark:'#1A7A70', line:'到操場集合！體育課開始囉！',
    questions:[
      { type:'text', q:'【待補充・範例題】浮潛時用嘴巴呼吸要透過什麼工具？', answer:'（範例答案）呼吸管' }
    ]
  }
];

let curSubjectIdx = 0, curQIdx = 0, revealed = false;

function goTo(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
}

function renderMenu(){
  const grid = document.getElementById('subject-grid');
  grid.innerHTML = '';
  subjects.forEach((s, i)=>{
    const card = document.createElement('button');
    card.className = 'card';
    card.style.setProperty('--c', s.color);
    card.innerHTML = `<span class="ic">${s.icon}</span><div class="nm display">${s.name}</div><div class="ct">共 ${s.questions.length} 題</div>`;
    card.onclick = ()=> openSubject(i);
    grid.appendChild(card);
  });
}

function openSubject(i){
  curSubjectIdx = i;
  const s = subjects[i];
  const intro = document.getElementById('screen-intro');
  intro.style.setProperty('--c', s.color);
  intro.style.setProperty('--cd', s.colorDark);
  document.getElementById('intro-icon').textContent = s.icon;
  document.getElementById('intro-name').textContent = s.name + '課';
  document.getElementById('intro-line').textContent = s.line;
  goTo('intro');
}

function startQuestions(){
  curQIdx = 0;
  loadQuestion();
  goTo('question');
}

function loadQuestion(){
  revealed = false;
  const s = subjects[curSubjectIdx];
  const q = s.questions[curQIdx];

  document.getElementById('q-subj-pill').style.setProperty('--c', s.color);
  document.getElementById('q-subj-icon').textContent = s.icon;
  document.getElementById('q-subj-name').textContent = s.name;
  document.getElementById('q-text').textContent = q.q;
  const imgEl = document.getElementById('q-image');
  if(q.image){ imgEl.src = q.image; imgEl.style.display = 'block'; }
  else{ imgEl.style.display = 'none'; imgEl.removeAttribute('src'); }
  document.getElementById('q-counter').textContent = `第 ${curQIdx+1} / ${s.questions.length} 題`;

  // dots
  const dots = document.getElementById('progress-dots');
  dots.innerHTML = '';
  s.questions.forEach((_, idx)=>{
    const d = document.createElement('span');
    d.className = 'dot' + (idx < curQIdx ? ' done' : '') + (idx === curQIdx ? ' now' : '');
    dots.appendChild(d);
  });

  // options
  const optWrap = document.getElementById('q-options');
  optWrap.innerHTML = '';
  if(q.type === 'choice'){
    const letters = ['A','B','C','D'];
    q.options.forEach((opt, idx)=>{
      const el = document.createElement('div');
      el.className = 'opt';
      el.dataset.idx = idx;
      el.innerHTML = `<span class="lbl accent">${letters[idx]}</span><span>${opt}</span>`;
      optWrap.appendChild(el);
    });
  }

  document.getElementById('answer-box').classList.remove('show');
  document.getElementById('answer-text').textContent = q.type === 'text' ? q.answer : (q.options[q.answerIndex]);
  document.getElementById('btn-reveal').style.display = 'inline-block';

  document.getElementById('btn-prev').disabled = (curQIdx === 0);
  const isLast = curQIdx === s.questions.length - 1;
  document.getElementById('btn-next').textContent = isLast ? '完成本單元 🎉' : '下一題 ▶';
}

function revealAnswer(){
  if(revealed) return;
  revealed = true;
  const s = subjects[curSubjectIdx];
  const q = s.questions[curQIdx];
  if(q.type === 'choice'){
    document.querySelectorAll('.opt').forEach(el=>{
      if(parseInt(el.dataset.idx) === q.answerIndex){ el.classList.add('correct'); }
      else{ el.classList.add('faded'); }
    });
  }
  document.getElementById('answer-box').classList.add('show');
}

function nextQuestion(){
  const s = subjects[curSubjectIdx];
  if(curQIdx < s.questions.length - 1){
    curQIdx++;
    loadQuestion();
  } else {
    showComplete();
  }
}
function prevQuestion(){
  if(curQIdx > 0){ curQIdx--; loadQuestion(); }
}

function showComplete(){
  const s = subjects[curSubjectIdx];
  const el = document.getElementById('screen-complete');
  el.style.setProperty('--c', s.color);
  el.style.setProperty('--cd', s.colorDark);
  document.getElementById('complete-title').textContent = s.name + '課上完囉！';
  const isLastSubject = curSubjectIdx === subjects.length - 1;
  document.getElementById('btn-next-subject').style.display = isLastSubject ? 'none' : 'inline-block';
  goTo('complete');
}

function nextSubject(){
  if(curSubjectIdx < subjects.length - 1){
    openSubject(curSubjectIdx + 1);
  }
}

renderMenu();

// keyboard shortcuts
document.addEventListener('keydown', (e)=>{
  const active = document.querySelector('.screen.active').id;
  if(active === 'screen-question'){
    if(e.code === 'Space' || e.code === 'Enter'){ e.preventDefault(); revealed ? nextQuestion() : revealAnswer(); }
    else if(e.code === 'ArrowRight'){ revealed ? nextQuestion() : revealAnswer(); }
    else if(e.code === 'ArrowLeft'){ prevQuestion(); }
    else if(e.code === 'Escape'){ goTo('menu'); }
  } else if(active === 'screen-intro'){
    if(e.code === 'Space' || e.code === 'Enter'){ startQuestions(); }
  } else if(active === 'screen-menu'){
    if(e.code === 'Escape'){ goTo('home'); }
  }
});
</script>
</body>
</html>
